# Supply Chain Intelligence Platform — Azure Configuration
#
# Copy this file to .env and fill in your values.
# Run infra/provision.sh to create all Azure resources and get these values.
#
# SECURITY: Never commit .env to git. It is in .gitignore.
# In CI/CD: set these as GitHub Actions secrets or Azure DevOps pipeline variables.
# In Azure: use Managed Identity — these variables are NOT needed.

# ── Azure Data Lake Storage Gen2 ─────────────────────────────────────────────
# Storage account name (NOT the full URL, just the name)
AZURE_STORAGE_ACCOUNT_NAME=

# ADLS filesystem (container) name — default: supply-chain
AZURE_STORAGE_FILESYSTEM=supply-chain

# ── Azure Key Vault ───────────────────────────────────────────────────────────
# Full Key Vault URL — e.g. https://kv-supply-chain-xxxx.vault.azure.net/
AZURE_KEY_VAULT_URL=

# ── Azure ML Workspace ────────────────────────────────────────────────────────
AZURE_SUBSCRIPTION_ID=
AZURE_ML_RESOURCE_GROUP=
AZURE_ML_WORKSPACE_NAME=
AZURE_ML_EXPERIMENT_NAME=supply-chain-demand-forecasting

# ── Service Principal (CI/CD only) ────────────────────────────────────────────
# Leave blank for local dev — DefaultAzureCredential will use 'az login' instead.
# Set these in GitHub Actions secrets for automated pipeline runs.
AZURE_TENANT_ID=
AZURE_CLIENT_ID=
AZURE_CLIENT_SECRET=
